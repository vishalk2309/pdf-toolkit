# Copy this file to ".env" and fill in your values.
# The backend reads these on startup (via python-dotenv).

# --- Database backend ---
# "sqlite" (default): a local users.db file. No server, no admin rights needed.
# "mysql":            use the MYSQL_* settings below (for production/deploy).
DB_ENGINE=sqlite

# --- MySQL / MariaDB connection (only used when DB_ENGINE=mysql) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=pdfvish

# --- Auth ---
# Secret used to sign JWT tokens. Use a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string

# --- Email (verification codes) ---
# Backend 0 (preferred on Render): Brevo HTTP API. Works over HTTPS, so it isn't
# blocked by hosts that disable outbound SMTP (Render does). Verify a single
# sender email in Brevo (no domain needed) and put it in MAIL_FROM.
BREVO_API_KEY=

# Backend 1: SMTP (e.g. Gmail). NOTE: Render blocks outbound SMTP, so this only
# works locally. Used when SMTP_USER and SMTP_PASS are set.
# For Gmail: enable 2-Step Verification, then create an "App password"
# (Google Account -> Security -> App passwords) and use it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_16_char_app_password

# Backend 2 (fallback): Resend API, used only if SMTP isn't configured.
RESEND_API_KEY=

# Display sender. For Gmail SMTP this should usually be your SMTP_USER address.
MAIL_FROM=PDFVish <youraddress@gmail.com>

# Set to "false" in production so verification codes are never returned in API
# responses. When no email backend works and this is "true", the code is shown
# on-screen/in logs so the flow stays testable.
AUTH_DEV_MODE=true

# Public base URL of the deployed app, used to build absolute links in emails
# (e.g. the password-reset link). Example: https://pdfvish.onrender.com
APP_BASE_URL=

# --- Social login (Google) ---
# OAuth 2.0 Web Client ID from Google Cloud Console
# (APIs & Services -> Credentials). Add your site to "Authorized JavaScript
# origins". Leave empty to hide the "Continue with Google" button.
GOOGLE_CLIENT_ID=
